# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# PostgreSQL (used by market-data and paper-trade services)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sportsbetting
POSTGRES_USER=sportsbetting
POSTGRES_PASSWORD=changeme

# market-data service
MARKET_DATA_PORT=8081
# How often to poll for new odds (seconds)
MARKET_DATA_POLL_INTERVAL=60

# paper-trade service
PAPER_TRADE_PORT=8082
# Minimum edge required before a paper bet is recorded (0.03 = 3%)
PAPER_TRADE_MIN_EDGE=0.03
# Kelly fraction to apply (0.25 = quarter Kelly)
PAPER_TRADE_KELLY_FRACTION=0.25
# Starting paper bankroll in USD
PAPER_TRADE_STARTING_BANKROLL=10000

# Bookmaker API credentials (Phase 9 — leave blank until live execution)
# BOOKMAKER_API_KEY=
# BOOKMAKER_API_SECRET=
# BOOKMAKER_API_BASE_URL=
