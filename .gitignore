# Local data — persisted outside Docker volumes for development use
# Never commit raw data, exports, or fixture CSVs
# Leading slash anchors to the repo root so src/bet/data/ and tests/data/ are not excluded.
/data/
tmp/

# Secrets — use .env.example to document required variables
.env
*.env
!.env.example

# Go build artifacts
/bin/
/market-data
/paper-trade
*.exe
*.test
*.out

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
*.egg-info/
dist/
build/
.ruff_cache/
.mypy_cache/

# macOS
.DS_Store

# IDE
.idea/
.vscode/
*.swp
